# --- Supabase credentials -------------------------------------------------
# Project URL: Supabase Dashboard -> Project Settings -> API -> Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# service_role key: Supabase Dashboard -> Project Settings -> API -> Project API keys
# This is a SECRET. It is used server-side only and must never be exposed
# in a browser or committed to git.
SUPABASE_KEY=your-service-role-key

# --- App ------------------------------------------------------------------
# Port the API listens on (optional, defaults to 3000)
PORT=3000
