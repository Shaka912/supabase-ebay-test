# --- Supabase credentials -------------------------------------------------
# Project URL: Supabase Dashboard -> Project Settings -> API -> Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Server-side SECRET key (bypasses Row Level Security):
#   New projects:   Dashboard -> Project Settings -> API Keys -> Secret keys
#                   (the value starts with "sb_secret_")
#   Older projects: the "service_role" key under Project API keys
# Used server-side only. Never expose it in a browser or commit it to git.
# NOTE: the "publishable"/"anon" key will NOT work here — RLS blocks its writes.
SUPABASE_KEY=your-secret-or-service-role-key

# --- Database (only needed for `npm run db:migrate`) -----------------------
# Postgres connection string: Dashboard -> Project Settings -> Database ->
# Connection string -> URI. Replace [YOUR-PASSWORD] with your database password.
# Not used by the API itself, only by the migration script.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# --- App ------------------------------------------------------------------
# Port the API listens on (optional, defaults to 3000)
PORT=3000
